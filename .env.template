# === Mission Control Configuration ===

# General API Key for external client access (X-API-Key header)
API_KEY=your_api_key_here

# === Authentication ===
# Primary administrator credentials (bootstrap)
# Changing these values updates the admin login immediately.
AUTH_USER=admin
AUTH_PASS=your_secure_password_here

# Mission Control - Config Overrides
DOCUMENTS_ROOT=~/.openclaw/workspace/docs
RESEARCH_PATH=~/.openclaw/workspace/docs/research
PLANS_PATH=~/.openclaw/workspace/docs/plans

# OpenClaw
OPENCLAW_WORKSPACE=/path/to/workspace
DATABASE_URL=./mission-control.db
