# Mission Control environment template
#
# Copy this file to `.env` and fill in only what your deployment needs.
# For a same-machine local setup, the defaults below are usually enough.

# Required for external API clients that use the `X-API-Key` header.
API_KEY=replace_with_a_real_api_key

# Admin login bootstrap. On a brand-new database, these values seed the first user.
AUTH_USER=admin
AUTH_PASS=replace_with_a_real_password

# SQLite database path. Relative paths resolve from the repo root.
DATABASE_URL=./mission-control.db

# Local OpenClaw workspace used for discovery and document/memory indexing.
OPENCLAW_WORKSPACE=~/openclaw/workspace

# OpenClaw runtime gateway transport.
# Same-machine local default:
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Optional when the gateway requires auth.
OPENCLAW_GATEWAY_TOKEN=
# Optional timeout override in milliseconds.
OPENCLAW_GATEWAY_TIMEOUT_MS=10000

# Optional workspace root overrides for document/memory scanning.
# Only set these if your layout differs from the normal OpenClaw workspace shape.
# DOCUMENTS_ROOT=~/.openclaw/workspace/docs
# DOCS_ROOT=~/.openclaw/workspace/docs
# MEMORY_ROOT=~/.openclaw/workspace/memory
# TMP_ROOT=~/.openclaw/workspace/tmp

# Advanced/debug override for OpenClaw's current internal gateway SDK file.
# Do not set this in normal installs.
# OPENCLAW_GATEWAY_SDK_CALL_PATH=

# Optional prefixed variants also work for config-backed keys:
# MC_API_KEY=
# MC_OPENCLAW_GATEWAY_URL=
